#: src/rust-2018/cargo-and-crates-io/cargo-check-for-faster-checking.md:23
#: src/rust-2018/cargo-and-crates-io/cargo-check-for-faster-checking.md:41
msgid "Run `cargo test` to make sure your tests pass."
msgstr ""

#: src/rust-2018/cargo-and-crates-io/cargo-check-for-faster-checking.md:24
msgid "Try the binary yourself"
msgstr ""

#: src/rust-2018/cargo-and-crates-io/cargo-check-for-faster-checking.md:25
#: src/rust-2018/cargo-and-crates-io/cargo-check-for-faster-checking.md:43
msgid "GOTO 1."
